"""
Copy this file to creds.py (same directory). creds.py itself is gitignored.

ACCOUNTS is no longer a hardcoded dict here -- broker credentials (api_key,
api_secret, password, TOTP secret) are stored encrypted in Postgres
(accounts + account_credentials tables) and decrypted at import time via
Algo/utils/crypto.py. Register a new account or rotate an existing one's
credentials with:

    python db/register_account.py

That script needs DATABASE_URL and CREDS_ENCRYPTION_KEY set in the
environment. Generate a CREDS_ENCRYPTION_KEY once with:

    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

Only fill in the telegram block below -- it's the one thing that still lives
in this local, gitignored file.
"""
from Algo.utils.db import load_account_credentials

ACCOUNTS = load_account_credentials()

telegram = {
    "is_debug_mode": False,
    "eqt_token": {"bot_id": "", "chat_id": ""},
    "tech_token": {"bot_id": "", "chat_id": ""},
}
